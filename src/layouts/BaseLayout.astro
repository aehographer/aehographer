---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'aehographer',
  description = '사랑하고 좋아하는 것들을 기록합니다.',
  image = '/og-image.png',
} = Astro.props;

const siteUrl = 'https://aehographer.com';
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⛵</text></svg>" />

    <!-- Open Graph (카카오, 페이스북 등) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="aehographer" />
    <meta property="og:locale" content="ko_KR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo">⛵</a>
      <div class="nav-links">
        <a href="/aeho" class:list={[{ active: Astro.url.pathname.startsWith('/aeho') }]}>aeho</a>
        <a href="/grapher" class:list={[{ active: Astro.url.pathname.startsWith('/grapher') }]}>grapher</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} aehographer</p>
    </footer>
  </body>
</html>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.2rem 1.5rem;
    background: rgba(11, 18, 33, 0.85);
    backdrop-filter: blur(12px);
  }

  .nav-logo {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--text);
    font-size: 0.95rem;
  }

  .nav-links a.active,
  .nav-links a:hover {
    color: var(--accent);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: #484f58;
    border-top: 1px solid var(--border);
  }
</style>
