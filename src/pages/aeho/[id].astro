---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('aeho');
  return items.map((item) => ({ params: { id: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const d = item.data;
---

<BaseLayout title={`${d.title} — aeho`}>
  <article>
    <a href="/aeho" class="back">← 목록으로</a>

    {d.image && !d.hideHeader && (
      <div class={`hero-image ${d.imageFit === 'contain' ? 'fit-contain' : 'fit-cover'}`}>
        <img src={d.image} alt={d.title} style={d.imagePosition ? `object-position: ${d.imagePosition};` : ''} />
      </div>
    )}

    <header>
      <span class="category">{d.tags?.join(' > ') || ''}</span>
      <h1>{d.title}</h1>
      {d.oneliner && <p class="oneliner">{d.oneliner}</p>}
    </header>

    <div class="meta">
      <span>{d.date}</span>
      {d.author && <span>저자: {d.author}</span>}
      {d.publisher && <span>출판사: {d.publisher}</span>}
      {d.venue && <span>장소: {d.venue}</span>}
      {d.seat && <span>좌석: {d.seat}</span>}
      {d.casting && <span>캐스팅: {d.casting}</span>}
      {d.artist && <span>아티스트: {d.artist}</span>}
      {d.channel && <span>채널: {d.channel}</span>}
      {d.link && <span>링크: <a href={d.link} target="_blank" rel="noopener noreferrer" aria-label="링크 열기">🔗</a></span>}
    </div>

    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    padding: 2rem 0;
  }

  .back {
    font-size: 0.85rem;
    color: #8b949e;
  }

  .back:hover {
    color: var(--accent);
  }

  .hero-image {
    margin: 2rem 0;
    border-radius: 8px;
    overflow: hidden;
    max-height: 400px;
    background: var(--bg-secondary);
  }

  .hero-image.fit-cover img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    object-position: center;
  }

  .hero-image.fit-contain {
    display: flex;
    justify-content: center;
  }

  .hero-image.fit-contain img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
  }

  header {
    margin: 2rem 0 1.5rem;
  }

  .category {
    font-size: 0.8rem;
    color: var(--accent);
    background: rgba(227, 188, 94, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
  }

  h1 {
    font-size: 1.8rem;
    color: var(--text-heading);
    margin: 0.8rem 0 0.5rem;
  }

  .oneliner {
    color: #8b949e;
    font-size: 1rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    color: #8b949e;
  }

  .content {
    padding-top: 2rem;
    line-height: 1.8;
  }

  .content :global(p) {
    margin: 0 0 0.6rem;
  }

  .content :global(blockquote) {
    margin: 0.6rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    color: #8b949e;
  }

  .content :global(h2) {
    margin: 1.8rem 0 0.8rem;
  }

  .content :global(h3) {
    margin: 1.4rem 0 0.6rem;
  }

  .content :global(hr) {
    margin: 1.2rem 0;
    border: none;
    border-top: 1px solid var(--border);
  }

  .content :global(img) {
    margin: 1.5rem 0;
    border-radius: 8px;
  }

  .content :global(aside) {
    background: var(--bg-secondary);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1rem 1.2rem;
    margin: 1.2rem 0;
    font-size: 0.92rem;
  }

  .content :global(aside > p:first-child) {
    font-weight: 600;
    color: var(--text-heading);
  }

  .content :global(aside > p:last-child) {
    margin-bottom: 0;
  }

  .content :global(aside ul),
  .content :global(aside ol) {
    margin: 0.4rem 0 0;
    padding-left: 1.2rem;
  }

  .content :global(aside li) {
    margin: 0.2rem 0;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 0.6rem 0;
    padding-left: 1.4rem;
  }

  .content :global(li) {
    margin: 0.3rem 0;
  }
</style>
