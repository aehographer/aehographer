---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('grapher'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const featured = (await getCollection('aeho'))
  .filter((p) => !p.data.draft && typeof p.data.featured === 'number')
  .sort((a, b) => (a.data.featured as number) - (b.data.featured as number))
  .slice(0, 3);
---

<BaseLayout title="aehographer">
  <section class="hero">
    <div class="hero-left">
      <h1>aehographer</h1>
      <p class="subtitle">사랑하고 좋아하는 것들을 기록합니다.</p>
      <img src="/aehographer-portrait.png" alt="aehographer" class="hero-illust" />
    </div>

    {featured.length > 0 && (
      <div class="hero-right">
        <h2>요즘 좋아하는 것들</h2>
        <ul class="featured-list">
          {featured.map((item) => {
            const sub = item.data.tags[1] || item.data.tags[0] || '';
            return (
              <li>
                <a href={`/aeho/${item.id}`} class="featured-item">
                  <div class="thumb">
                    {item.data.image ? (
                      <img src={item.data.image} alt={item.data.title} />
                    ) : (
                      <div class="thumb-placeholder">{sub}</div>
                    )}
                  </div>
                  <div class="featured-meta">
                    <span class="category">{sub}</span>
                    <h3>{item.data.title}</h3>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
        <a href="/aeho" class="view-all">aeho 전체 보기 →</a>
      </div>
    )}
  </section>

  <section class="recent">
    <h2>최근 글</h2>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/grapher/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{post.data.date}</span>
          </a>
        </li>
      ))}
    </ul>
    <a href="/grapher" class="view-all">모든 글 보기 →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 3rem 0 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .hero-left h1 {
    font-size: 2.4rem;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: #8b949e;
    margin-bottom: 1.5rem;
  }

  .hero-illust {
    width: 100%;
    max-width: 260px;
    height: auto;
    border-radius: 8px;
  }

  .hero-right h2 {
    font-size: 1.05rem;
    color: var(--text-heading);
    margin-bottom: 1rem;
  }

  .featured-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .featured-item {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    color: var(--text);
    padding: 0.4rem 0;
    transition: transform 0.2s;
  }

  .featured-item:hover {
    transform: translateX(3px);
  }

  .thumb {
    width: 56px;
    height: 75px;
    flex-shrink: 0;
    border-radius: 5px;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #484f58;
    font-size: 0.7rem;
  }

  .featured-meta {
    min-width: 0;
    flex: 1;
  }

  .category {
    font-size: 0.7rem;
    color: var(--accent);
  }

  .featured-meta h3 {
    font-size: 0.9rem;
    color: var(--text-heading);
    margin: 0.15rem 0 0;
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .featured-item:hover h3 {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 0;
    }

    .hero-illust {
      max-width: 200px;
    }
  }

  .recent {
    padding: 2rem 0;
  }

  .recent h2 {
    font-size: 1.2rem;
    color: var(--text-heading);
    margin-bottom: 1.5rem;
  }

  .recent ul {
    list-style: none;
  }

  .recent li {
    border-bottom: 1px solid var(--border);
  }

  .recent li a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    color: var(--text);
  }

  .recent li a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    transition: color 0.2s;
  }

  .post-date {
    font-size: 0.85rem;
    color: #484f58;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: 0.9rem;
  }
</style>
